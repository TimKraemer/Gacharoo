{
	"name": "gacharoo",
	"version": "0.1.0",
	"private": true,
	"scripts": {
		"dev": "next dev --turbopack",
		"build": "GACHAROO_DATABASE_URL_FALLBACK=1 next build",
		"start": "next start",
		"lint": "biome check .",
		"test": "bun test",
		"lint:fix": "biome check --write .",
		"format": "biome format --write .",
		"db:generate": "drizzle-kit generate",
		"db:push": "drizzle-kit push",
		"db:migrate": "drizzle-kit migrate",
		"db:studio": "drizzle-kit studio",
		"brand:generate": "bun run scripts/generate-gacharoo-brand-assets.ts",
		"git:hooks": "git config core.hooksPath .githooks",
		"git:assert-pushed": "bash scripts/assert-pushed-to-origin.sh"
	},
	"dependencies": {
		"@dicebear/collection": "^9.4.1",
		"@dicebear/core": "^9.4.1",
		"@react-spring/three": "^10.0.3",
		"@react-spring/web": "^10.0.3",
		"@react-three/drei": "^10.7.7",
		"@react-three/fiber": "^9.5.0",
		"better-auth": "^1.5.5",
		"drizzle-orm": "^0.45.1",
		"nanoid": "^5.1.7",
		"next": "16.2.0",
		"next-intl": "^4.8.3",
		"papaparse": "^5.5.3",
		"postgres": "^3.4.8",
		"react": "19.2.4",
		"react-dom": "19.2.4",
		"react-sketch-canvas": "^6.2.0",
		"react-tinder-card": "^1.6.4",
		"sharp": "^0.34.5",
		"three": "0.183.2",
		"zustand": "^5.0.12"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.8",
		"@tailwindcss/postcss": "^4",
		"@types/node": "^20",
		"@types/papaparse": "^5.5.2",
		"@types/react": "^19",
		"@types/react-dom": "^19",
		"@types/three": "0.183.1",
		"drizzle-kit": "^0.31.10",
		"tailwindcss": "^4",
		"typescript": "^5"
	},
	"ignoreScripts": [
		"sharp",
		"unrs-resolver"
	],
	"trustedDependencies": [
		"sharp",
		"unrs-resolver"
	]
}
